<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:pages="clr-namespace:GastoApp.Pages"
       x:Class="GastoApp.AppShell"
       Shell.NavBarIsVisible="True"
       Shell.FlyoutIsPresented="False"
       Shell.BackgroundColor="#1D9E75"
       Shell.ForegroundColor="White"
       Shell.TitleColor="White"
       Shell.TabBarBackgroundColor="White"
       Shell.TabBarForegroundColor="#1D9E75"
       Shell.TabBarUnselectedColor="#9CA3AF"
       FlyoutBehavior="Flyout">

  
    <Shell.FlyoutHeader>
        <Grid BackgroundColor="#1D9E75"
              Padding="24,48,24,24"
              RowDefinitions="Auto,Auto,Auto">

           
            <Border Grid.Row="0"
                    BackgroundColor="#FFFFFF33"
                    Stroke="Transparent"
                    WidthRequest="64" HeightRequest="64"
                    HorizontalOptions="Start"
                    Margin="0,0,0,12">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="32" />
                </Border.StrokeShape>
                <Label x:Name="LblIniciales"
                       Text="CG"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Border>

            <Label Grid.Row="1"
                   x:Name="LblNombreUsuario"
                   Text="Carlos García"
                   FontSize="17"
                   FontAttributes="Bold"
                   TextColor="White" />

            <Label Grid.Row="2"
                   x:Name="LblCorreoUsuario"
                   Text="admin"
                   FontSize="13"
                   TextColor="#FFFFFFAA" />
        </Grid>
    </Shell.FlyoutHeader>

 
    <FlyoutItem Title="Inicio" Icon="home.png" Route="home">
        <ShellContent ContentTemplate="{DataTemplate pages:HomePage}" />
    </FlyoutItem>

  
    <FlyoutItem Title="Gastos" Icon="wallet.png" Route="gastos">
        <ShellContent ContentTemplate="{DataTemplate pages:GastosListPage}" />
    </FlyoutItem>

    
    <FlyoutItem Title="Categorías" Icon="tag.png" Route="categorias">
        <ShellContent ContentTemplate="{DataTemplate pages:CategoriasListPage}" />
    </FlyoutItem>

    
    <FlyoutItem Title="Presupuestos" Icon="chart.png" Route="presupuestos">
        <ShellContent ContentTemplate="{DataTemplate pages:PresupuestosListPage}" />
    </FlyoutItem>

    
    <FlyoutItem Title="Usuarios" Icon="person.png" Route="usuarios">
        <ShellContent ContentTemplate="{DataTemplate pages:UsuariosListPage}" />
    </FlyoutItem>

    
    <Shell.FlyoutFooter>
        <VerticalStackLayout Padding="16,8,16,40" Spacing="0">
            <BoxView HeightRequest="1" Color="#E5E7EB" Margin="0,0,0,12" />
            <Button Text="🚪  Cerrar sesión"
                    BackgroundColor="#FEE2E2"
                    TextColor="#EF4444"
                    CornerRadius="12"
                    HeightRequest="46"
                    FontSize="14"
                    Clicked="OnCerrarSesionClicked" />
        </VerticalStackLayout>
    </Shell.FlyoutFooter>

</Shell>
