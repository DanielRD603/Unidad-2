<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GastoApp.Pages.GastoFormPage"
             Title="Nuevo Gasto">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Guardar" Clicked="OnGuardarClicked"/>
    </ContentPage.ToolbarItems>
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="0">

            <Label Text="DATOS DEL GASTO" Style="{StaticResource SectionLabel}"/>
            <Border Style="{StaticResource Card}" Padding="16" Margin="0,0,0,12">
                <VerticalStackLayout Spacing="14">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Descripción *" FontSize="13" TextColor="{StaticResource TextSecondary}"/>
                        <Border Style="{StaticResource FieldBorder}">
                            <Entry x:Name="EntryDescripcion" Placeholder="Ej. Almuerzo" ReturnType="Next"/>
                        </Border>
                    </VerticalStackLayout>
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Monto (RD$) *" FontSize="13" TextColor="{StaticResource TextSecondary}"/>
                        <Border Style="{StaticResource FieldBorder}">
                            <Entry x:Name="EntryMonto" Placeholder="0.00" Keyboard="Numeric" ReturnType="Next"/>
                        </Border>
                    </VerticalStackLayout>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0" Spacing="6">
                            <Label Text="Fecha *" FontSize="13" TextColor="{StaticResource TextSecondary}"/>
                            <Border Style="{StaticResource FieldBorder}">
                                <DatePicker x:Name="DatePickerFecha" Format="dd/MM/yyyy"/>
                            </Border>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="6">
                            <Label Text="Hora" FontSize="13" TextColor="{StaticResource TextSecondary}"/>
                            <Border Style="{StaticResource FieldBorder}">
                                <TimePicker x:Name="TimePickerHora" Format="hh:mm tt"/>
                            </Border>
                        </VerticalStackLayout>
                    </Grid>
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Categoría *" FontSize="13" TextColor="{StaticResource TextSecondary}"/>
                        <Border Style="{StaticResource FieldBorder}">
                            <Picker x:Name="PickerCategoria" Title="Selecciona una categoría">
                                <Picker.Items>
                                    <x:String>Comida</x:String>
                                    <x:String>Transporte</x:String>
                                    <x:String>Ocio</x:String>
                                    <x:String>Servicios</x:String>
                                    <x:String>Salud</x:String>
                                    <x:String>Otro</x:String>
                                </Picker.Items>
                            </Picker>
                        </Border>
                    </VerticalStackLayout>
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Notas (opcional)" FontSize="13" TextColor="{StaticResource TextSecondary}"/>
                        <Border Style="{StaticResource FieldBorder}">
                            <Editor x:Name="EditorNotas" Placeholder="Agrega una nota..." HeightRequest="72"/>
                        </Border>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Button Text="💾  Guardar gasto" Style="{StaticResource PrimaryButton}"
                    Clicked="OnGuardarClicked" Margin="0,4,0,10"/>
            <Button x:Name="BtnEliminar" Text="🗑️  Eliminar gasto"
                    Style="{StaticResource DangerButton}"
                    IsVisible="False" Clicked="OnEliminarClicked" Margin="0,0,0,32"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
