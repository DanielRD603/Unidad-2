<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GastoApp.Pages.ResumenPage"
             Title="Resumen">
    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="12">
        <Label Text="📊" FontSize="56" HorizontalOptions="Center" />
        <Label Text="Resumen y estadísticas"
               Style="{StaticResource TitleLabel}"
               HorizontalOptions="Center" />
        <Label Text="Disponible en la próxima unidad"
               Style="{StaticResource SubtitleLabel}"
               HorizontalOptions="Center" />
    </VerticalStackLayout>
</ContentPage>
