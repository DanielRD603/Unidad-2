<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GastoApp.Pages.GastosListPage"
             Title="Gastos">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="+" Clicked="OnAgregarClicked" />
    </ContentPage.ToolbarItems>
    <Grid RowDefinitions="Auto,*" Padding="16,12">
        <Label Grid.Row="0" x:Name="LblConteo"
               Style="{StaticResource SubtitleLabel}" Margin="0,0,0,10" />
        <CollectionView Grid.Row="1" x:Name="Lista" SelectionMode="Single"
                        SelectionChanged="OnSeleccionado">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource Card}" Padding="14" Margin="0,0,0,10">
                        <Grid ColumnDefinitions="46,*,Auto" ColumnSpacing="12">
                            <Border Grid.Column="0" Style="{StaticResource IconBadge}"
                                    BackgroundColor="{StaticResource CatComidaBg}">
                                <Label Text="💳" FontSize="20"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="3">
                                <Label Text="{Binding Descripcion}" FontSize="15"
                                       FontAttributes="Bold" TextColor="{StaticResource TextPrimary}"/>
                                <Label Text="{Binding Fecha, StringFormat='{0:dd MMM yyyy}'}"
                                       FontSize="12" TextColor="{StaticResource TextSecondary}"/>
                                <Border BackgroundColor="{StaticResource PrimaryLight}"
                                        Stroke="Transparent" Padding="6,2">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="6"/></Border.StrokeShape>
                                    <Label Text="{Binding Categoria}" FontSize="11"
                                           TextColor="{StaticResource Primary}" FontAttributes="Bold"/>
                                </Border>
                            </VerticalStackLayout>
                            <Label Grid.Column="2"
                                   Text="{Binding Monto, StringFormat='-RD$ {0:N2}'}"
                                   FontSize="15" FontAttributes="Bold"
                                   TextColor="{StaticResource Danger}"
                                   VerticalOptions="Center"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center"
                                     Spacing="12" Margin="0,60,0,0">
                    <Label Text="💸" FontSize="52" HorizontalOptions="Center"/>
                    <Label Text="Sin gastos registrados"
                           Style="{StaticResource SubtitleLabel}" HorizontalOptions="Center"/>
                    <Button Text="+ Agregar gasto" Style="{StaticResource PrimaryButton}"
                            WidthRequest="200" HorizontalOptions="Center"
                            Clicked="OnAgregarClicked"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>
    </Grid>
</ContentPage>
