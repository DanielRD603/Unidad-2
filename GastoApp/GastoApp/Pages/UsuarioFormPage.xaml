<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GastoApp.Pages.UsuarioFormPage" Title="Nuevo Usuario">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Guardar" Clicked="OnGuardarClicked"/>
    </ContentPage.ToolbarItems>
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="0">
            <Label Text="DATOS DEL USUARIO" Style="{StaticResource SectionLabel}"/>
            <Border Style="{StaticResource Card}" Padding="16" Margin="0,0,0,12">
                <VerticalStackLayout Spacing="14">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Nombre completo *" FontSize="13" TextColor="{StaticResource TextSecondary}"/>
                        <Border Style="{StaticResource FieldBorder}">
                            <Entry x:Name="EntryNombre" Placeholder="Ej. Carlos García" ReturnType="Next"/>
                        </Border>
                    </VerticalStackLayout>
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Correo / Usuario *" FontSize="13" TextColor="{StaticResource TextSecondary}"/>
                        <Border Style="{StaticResource FieldBorder}">
                            <Entry x:Name="EntryCorreo" Placeholder="usuario@correo.com"
                                   Keyboard="Email" ReturnType="Next"/>
                        </Border>
                    </VerticalStackLayout>
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Contraseña *" FontSize="13" TextColor="{StaticResource TextSecondary}"/>
                        <Border Style="{StaticResource FieldBorder}">
                            <Entry x:Name="EntryClave" Placeholder="Mínimo 4 caracteres"
                                   IsPassword="True" ReturnType="Done"/>
                        </Border>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
            <Button Text="💾  Guardar usuario" Style="{StaticResource PrimaryButton}"
                    Clicked="OnGuardarClicked" Margin="0,4,0,10"/>
            <Button x:Name="BtnEliminar" Text="🗑️  Eliminar usuario"
                    Style="{StaticResource DangerButton}"
                    IsVisible="False" Clicked="OnEliminarClicked" Margin="0,0,0,32"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
