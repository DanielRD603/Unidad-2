<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GastoApp.Pages.HomePage"
             Title="Inicio">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="0">

            
            <Label x:Name="LblSaludo"
                   Text="Buen día 👋"
                   Style="{StaticResource TitleLabel}"
                   Margin="0,8,0,2" />
            <Label x:Name="LblFecha"
                   Text="Cargando..."
                   Style="{StaticResource SubtitleLabel}"
                   Margin="0,0,0,20" />

            
            <Border Margin="0,0,0,16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1D9E75" Offset="0" />
                        <GradientStop Color="#065F46" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid RowDefinitions="Auto,Auto,Auto,Auto" Padding="20">
                    <Label Grid.Row="0" Text="GASTO TOTAL DEL MES"
                           FontSize="11" FontAttributes="Bold"
                           TextColor="#FFFFFFAA" CharacterSpacing="1.5" />
                    <Label Grid.Row="1" x:Name="LblTotalMes"
                           Text="RD$ 0.00"
                           FontSize="36" FontAttributes="Bold"
                           TextColor="White" Margin="0,4,0,16" />
                    <BoxView Grid.Row="2" HeightRequest="1"
                             Color="#FFFFFF33" Margin="0,0,0,12" />
                    <Grid Grid.Row="3" ColumnDefinitions="*,*">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Presupuesto" FontSize="11" TextColor="#FFFFFFAA" />
                            <Label x:Name="LblPresupuesto" Text="RD$ 0.00"
                                   FontSize="15" FontAttributes="Bold" TextColor="White" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Disponible" FontSize="11" TextColor="#FFFFFFAA" />
                            <Label x:Name="LblDisponible" Text="RD$ 0.00"
                                   FontSize="15" FontAttributes="Bold" TextColor="White" />
                        </VerticalStackLayout>
                    </Grid>
                </Grid>
            </Border>

         
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12"
                  RowDefinitions="Auto" Margin="0,0,0,20">
                <Border Grid.Column="0" Style="{StaticResource Card}" Padding="14">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="💰" FontSize="22" />
                        <Label Text="Total gastos" FontSize="11"
                               TextColor="{StaticResource TextSecondary}" />
                        <Label x:Name="LblCantGastos" Text="0"
                               FontSize="18" FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource Card}" Padding="14">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="🏷️" FontSize="22" />
                        <Label Text="Categorías" FontSize="11"
                               TextColor="{StaticResource TextSecondary}" />
                        <Label x:Name="LblCantCategorias" Text="0"
                               FontSize="18" FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            
            <Label Text="ACCIONES RÁPIDAS" Style="{StaticResource SectionLabel}" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,0,0,20">
                <Button Grid.Column="0"
                        Text="+ Nuevo gasto"
                        Style="{StaticResource PrimaryButton}"
                        Clicked="OnNuevoGastoClicked" />
                <Button Grid.Column="1"
                        Text="Ver gastos"
                        Style="{StaticResource OutlineButton}"
                        Clicked="OnVerGastosClicked" />
            </Grid>

           
            <Label Text="ÚLTIMOS GASTOS" Style="{StaticResource SectionLabel}" />

            <Border Style="{StaticResource Card}" Padding="0" Margin="0,0,0,4">
                <VerticalStackLayout x:Name="StackRecientes" Spacing="0" />
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
