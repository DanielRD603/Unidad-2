<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GastoApp.Pages.CategoriaFormPage" Title="Nueva Categoría">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Guardar" Clicked="OnGuardarClicked"/>
    </ContentPage.ToolbarItems>
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="0">
            <Label Text="DATOS DE LA CATEGORÍA" Style="{StaticResource SectionLabel}"/>
            <Border Style="{StaticResource Card}" Padding="16" Margin="0,0,0,12">
                <VerticalStackLayout Spacing="14">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Nombre *" FontSize="13" TextColor="{StaticResource TextSecondary}"/>
                        <Border Style="{StaticResource FieldBorder}">
                            <Entry x:Name="EntryNombre" Placeholder="Ej. Comida" ReturnType="Next"/>
                        </Border>
                    </VerticalStackLayout>
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Ícono (emoji) *" FontSize="13" TextColor="{StaticResource TextSecondary}"/>
                        <Border Style="{StaticResource FieldBorder}">
                            <Entry x:Name="EntryIcono" Placeholder="Ej. 🍽️" ReturnType="Next"/>
                        </Border>
                    </VerticalStackLayout>
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Color (hex) *" FontSize="13" TextColor="{StaticResource TextSecondary}"/>
                        <Border Style="{StaticResource FieldBorder}">
                            <Entry x:Name="EntryColor" Placeholder="Ej. #1D9E75" ReturnType="Next"/>
                        </Border>
                    </VerticalStackLayout>
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Descripción" FontSize="13" TextColor="{StaticResource TextSecondary}"/>
                        <Border Style="{StaticResource FieldBorder}">
                            <Editor x:Name="EditorDescripcion" Placeholder="Describe esta categoría..."
                                    HeightRequest="72"/>
                        </Border>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
            <Button Text="💾  Guardar categoría" Style="{StaticResource PrimaryButton}"
                    Clicked="OnGuardarClicked" Margin="0,4,0,10"/>
            <Button x:Name="BtnEliminar" Text="🗑️  Eliminar categoría"
                    Style="{StaticResource DangerButton}"
                    IsVisible="False" Clicked="OnEliminarClicked" Margin="0,0,0,32"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
