<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GastoApp.Pages.LoginPage"
             NavigationPage.HasNavigationBar="False">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0F766E" Offset="0.0" />
            <GradientStop Color="#1D9E75" Offset="0.5" />
            <GradientStop Color="#065F46" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <ScrollView>
        <Grid RowDefinitions="*,Auto" MinimumHeightRequest="600">

            
            <VerticalStackLayout Grid.Row="0"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center"
                                 Spacing="8" Padding="0,60,0,0">

                <Border BackgroundColor="#FFFFFF20"
                        Stroke="Transparent"
                        WidthRequest="90" HeightRequest="90"
                        HorizontalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="26" />
                    </Border.StrokeShape>
                    <Label Text="💳" FontSize="42"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>

                <Label Text="GastoApp"
                       FontSize="32" FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center" />

                <Label Text="Tu dinero, bajo control"
                       FontSize="14" TextColor="#FFFFFFBB"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

          
            <Border Grid.Row="1"
                    BackgroundColor="White"
                    Stroke="Transparent"
                    Padding="28,32,28,40">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="32,32,0,0" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="0">

                    <Label Text="Bienvenido de vuelta"
                           FontSize="22" FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}"
                           Margin="0,0,0,4" />
                    <Label Text="Inicia sesión para continuar"
                           FontSize="14"
                           TextColor="{StaticResource TextSecondary}"
                           Margin="0,0,0,28" />

                  
                    <Label Text="USUARIO" Style="{StaticResource SectionLabel}" Margin="0,0,0,6" />
                    <Border Style="{StaticResource FieldBorder}" Margin="0,0,0,16">
                        <Entry x:Name="EntryCorreo"
                               Placeholder="Ingresa tu usuario"
                               Keyboard="Email"
                               ReturnType="Next" />
                    </Border>

                    
                    <Label Text="CONTRASEÑA" Style="{StaticResource SectionLabel}" Margin="0,0,0,6" />
                    <Border Style="{StaticResource FieldBorder}" Margin="0,0,0,28">
                        <Entry x:Name="EntryPassword"
                               Placeholder="Ingresa tu contraseña"
                               IsPassword="True"
                               ReturnType="Done" />
                    </Border>

                    <Button Text="Iniciar sesión"
                            Style="{StaticResource PrimaryButton}"
                            Clicked="OnLoginClicked" />

                    <Label Text="Grupo #02: usuario admin / clave 1234"
                           FontSize="12"
                           TextColor="{StaticResource TextHint}"
                           HorizontalOptions="Center"
                           Margin="0,16,0,0" />
                </VerticalStackLayout>
            </Border>

        </Grid>
    </ScrollView>
</ContentPage>
